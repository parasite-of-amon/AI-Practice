{
  "name": "stylehub",
  "version": "1.0.0",
  "description": "Fashion shopping website with Node.js, Express, and DuckDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:e2e": "playwright test",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "duckdb": "^1.1.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/unit/**/*.test.js",
      "**/tests/integration/**/*.test.js"
    ]
  },
  "allowScripts": {
    "duckdb@1.4.4": true
  }
}
